<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SpaceX Mission Dashboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <h1>🚀 SpaceX Mission Management System</h1>

    <div class="dashboard-links">
        <a href="/add-mission">Add Mission</a>
        |
        <a href="/logout">Logout</a>
    </div>

    <hr>

    <% if (missions.length === 0) { %>
        <h3>No Missions Found</h3>
    <% } %>

    <% missions.forEach(mission => { %>

        <div class="mission-card">

            <h2><%= mission.missionName %></h2>

            <p>
                <strong>Rocket Name:</strong>
                <%= mission.rocketName %>
            </p>

            <p>
                <strong>Launch Date:</strong>
                <%= new Date(mission.launchDate).toLocaleDateString() %>
            </p>

            <p>
                <strong>Description:</strong>
                <%= mission.description %>
            </p>

            <% if (mission.image) { %>
                <img
                    src="/<%= mission.image %>"
                    alt="<%= mission.missionName %>"
                >
            <% } %>

            <br>

            <a href="/edit-mission/<%= mission._id %>">Edit</a>
            |
            <a href="/delete-mission/<%= mission._id %>"
               onclick="return confirm('Are you sure you want to delete this mission?')">
               Delete
            </a>

        </div>

    <% }) %>

</body>
</html>