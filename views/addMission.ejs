```ejs
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Mission</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <h1>Add SpaceX Mission</h1>

    <form action="/add-mission" method="POST" enctype="multipart/form-data">

        <input
            type="text"
            name="missionName"
            placeholder="Mission Name"
            required
        >
        <br><br>

        <input
            type="text"
            name="rocketName"
            placeholder="Rocket Name"
            required
        >
        <br><br>

        <input
            type="date"
            name="launchDate"
            required
        >
        <br><br>

        <textarea
            name="description"
            placeholder="Mission Description"
            rows="5"
            cols="30"
            required
        ></textarea>
        <br><br>

        <input
            type="file"
            name="image"
            accept="image/*"
            required
        >
        <br><br>

        <button type="submit">
            Add Mission
        </button>

    </form>

    <br>

    <a href="/dashboard">
        Back to Dashboard
    </a>

</body>
</html>
```
