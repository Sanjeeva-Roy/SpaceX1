<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <h1>SpaceX Mission Management System</h1>
    <h2>Login</h2>

    <form action="/login" method="POST">

        <input
            type="email"
            name="email"
            placeholder="Enter Email"
            required
        >
        <br><br>

        <input
            type="password"
            name="password"
            placeholder="Enter Password"
            required
        >
        <br><br>

        <button type="submit">
            Login
        </button>

    </form>

    <br>

    <p>
        Don't have an account?
        <a href="/register">Register</a>
    </p>

</body>
</html>