<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <h1>SpaceX Mission Management System</h1>
    <h2>Register</h2>

    <form action="/register" method="POST">

        <input
            type="text"
            name="name"
            placeholder="Enter Name"
            required
        >
        <br><br>

        <input
            type="email"
            name="email"
            placeholder="Enter Email"
            required
        >
        <br><br>

        <input
            type="password"
            name="password"
            placeholder="Enter Password"
            required
        >
        <br><br>

        <button type="submit">
            Register
        </button>

    </form>

    <br>

    <p>
        Already have an account?
        <a href="/login">Login</a>
    </p>

</body>
</html>